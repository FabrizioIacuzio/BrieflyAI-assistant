# ── API Keys ──────────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here
NEWSAPI_KEY=your_newsapi_key_here      # optional

# ── Auth ──────────────────────────────────────────────────────────────────────
DEMO_USER=demo
DEMO_PASSWORD=demo123
SECRET_KEY=generate-with-openssl-rand-hex-32

# Google OAuth (console.cloud.google.com)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Database ──────────────────────────────────────────────────────────────────
# Leave blank for local SQLite. For Docker/production use PostgreSQL:
# DATABASE_URL=postgresql://briefly:yourpassword@db:5432/briefly
DATABASE_URL=

# Used by docker-compose to set the Postgres password
POSTGRES_PASSWORD=change-me-strong-password

# ── CORS / Frontend ───────────────────────────────────────────────────────────
# Where the React frontend lives (used for OAuth redirects and CORS)
FRONTEND_ORIGIN=http://localhost:5173

# In production, set this to your Vercel URL, e.g. https://briefly.vercel.app
# FRONTEND_ORIGIN=https://your-app.vercel.app

# Additional allowed CORS origins (comma-separated), e.g. staging URLs
EXTRA_CORS_ORIGINS=

# ── Runtime ───────────────────────────────────────────────────────────────────
# Set to false in production
DEBUG=true
